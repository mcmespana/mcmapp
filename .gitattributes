# Enforce LF line endings across the repo (avoids CRLF noise on Windows)
* text=auto eol=lf

# Binary assets — never touch their bytes
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.webp binary
*.pdf binary
*.zip binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.mp3 binary
*.mp4 binary
*.mov binary

# Suppress GitHub Actions linting warnings for workflow files
*.yml linguist-language=YAML
*.yaml linguist-language=YAML

# Treat workflow files as YAML for proper syntax highlighting
/.github/workflows/* linguist-language=YAML
