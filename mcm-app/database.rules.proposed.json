{
  "rules": {
    ".read": false,
    ".write": false,

    "songs": {
      "data": { ".read": true },
      "updatedAt": { ".read": true, ".write": true },
      "ediciones": { ".write": true },
      "solicitudes": { ".write": true },
      "fallitos": { ".write": true }
    },

    "albums": { ".read": true },

    "jubileo": {
      ".read": true,
      "compartiendo": { ".write": true }
    },

    "activities": { ".read": true },

    "profileConfig": { ".read": true },

    "calendars": { ".read": true },

    "seccion_oracion": { ".read": true },

    "notifications": { ".read": true },

    "wordle": {
      ".read": true,
      "daily-words": {},
      "stats": { ".write": true },
      "users": { ".write": true },
      "$date": { ".write": true }
    },

    "pushTokens": {
      "$tokenId": { ".write": true }
    },

    "app": {
      "feedback": { ".write": true }
    },

    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    }
  }
}
