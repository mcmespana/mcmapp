{
  "name": "mcm-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "format": "prettier --write '**/*.{js,jsx,ts,tsx,json,md}'",
    "test": "jest",
    "eas:build": "rm -rf .agent .agents && npx eas-cli@latest build",
    "eas:build:ios": "rm -rf .agent .agents && npx eas-cli@latest build -p ios",
    "eas:build:android": "rm -rf .agent .agents && npx eas-cli@latest build -p android"
  },
  "dependencies": {
    "@expo/config": "^55.0.7",
    "@expo/vector-icons": "^15.0.2",
    "@gorhom/bottom-sheet": "^5.2.9",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-community/slider": "5.1.2",
    "@react-native-picker/picker": "2.11.4",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/native-stack": "^7.3.10",
    "chordsheetjs": "^14.0.0",
    "expo": "^55.0.5",
    "expo-asset": "~55.0.8",
    "expo-blur": "~55.0.8",
    "expo-build-properties": "~55.0.9",
