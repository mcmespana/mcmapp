{
  "expo": {
    "name": "MCM App",
    "slug": "mcm-app",
    "version": "2.0.0",
    "runtimeVersion": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mcmapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.familiaconsolacion.mcmapp",
      "infoPlist": {
        "CFBundleDisplayName": "MCM App",
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": ["webcal"],
        "NSLocationWhenInUseUsageDescription": "La app puede usar tu ubicación para habilitar funciones basadas en ubicación cuando estén disponibles (por ejemplo, mostrar información relevante cerca de ti).",
        "LSSupportsOpeningDocumentsInPlace": true,
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "MCM Playlist",
            "CFBundleTypeRole": "Editor",
            "LSHandlerRank": "Owner",
            "LSItemContentTypes": ["com.mcmespana.mcmapp.playlist"]
          }
        ],
        "UTExportedTypeDeclarations": [
          {
            "UTTypeIdentifier": "com.mcmespana.mcmapp.playlist",
            "UTTypeDescription": "MCM Playlist",
            "UTTypeConformsTo": ["public.data", "public.json"],
            "UTTypeTagSpecification": {
              "public.filename-extension": ["mcm"],
              "public.mime-type": ["application/octet-stream"]
            }
          }
        ]
      },
      "appleTeamId": "5P53S6QB23",
      "associatedDomains": ["applinks:mcm.expo.app"]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.mcmespana.mcmapp",
      "blockedPermissions": ["android.permission.ACTIVITY_RECOGNITION"],
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "category": ["DEFAULT", "BROWSABLE"],
          "data": [
            {
              "scheme": "file",
              "mimeType": "*/*",
              "pathPattern": ".*\\.mcm"
            },
            {
              "scheme": "content",
              "mimeType": "*/*",
              "pathPattern": ".*\\.mcm"
            }
          ]
        },
        {
          "autoVerify": true,
          "action": "VIEW",
          "category": ["DEFAULT", "BROWSABLE"],
          "data": [
            {
              "scheme": "https",
              "host": "mcm.expo.app",
              "pathPrefix": "/playlist"
            },
            {
              "scheme": "https",
              "host": "mcm.expo.app",
              "pathPrefix": "/coro"
            }
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "meta": {
        "apple": {
          "mobileWebAppCapable": "yes",
          "statusBarStyle": "black-translucent",
          "title": "MCM App · Web",
          "touchIcon": "./assets/images/icon.png",
          "icons": {
            "120": "./assets/images/icon-120.png",
            "152": "./assets/images/icon-152.png",
            "167": "./assets/images/icon-167.png",
            "180": "./assets/images/icon-180.png"
          }
        },
        "viewport": "width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no"
      },
      "manifest": {
        "name": "MCM App · Web",
        "short_name": "MCM",
        "description": "Aplicación móvil de MCM España para seguimiento de actividades, cantoral y mucho más",
        "start_url": "/",
        "scope": "/",
        "display": "standalone",
        "orientation": "portrait",
        "background_color": "#ffffff",
        "theme_color": "#253883",
        "icons": [
          {
            "src": "./assets/images/icon-192.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "any maskable"
          },
          {
            "src": "./assets/images/icon-512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "any maskable"
          }
        ]
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon-light.png",
          "dark": {
            "image": "./assets/images/splash-icon-dark.png",
            "backgroundColor": "#000000"
          },
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/adaptive-icon.png",
          "color": "#253883",
          "sounds": [],
          "mode": "production"
        }
      ],
      "expo-asset",
      ["expo-build-properties"],
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-image",
      "expo-sharing",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "aa9f2d3a-b74a-4169-bad4-e851015e30c6"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/aa9f2d3a-b74a-4169-bad4-e851015e30c6",
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    }
  }
}
