{
  "env": {
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(node:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(npx expo install:*)",
      "Bash(npm install:*)",
      "Bash(npx expo-doctor:*)",
      "Bash(npm dedupe)",
      "Bash(npx tsc:*)",
      "Bash(cat:*)",
      "Bash(awk:*)",
      "Bash(xargs kill:*)",
      "Bash(eas credentials:*)",
      "Bash(npx eas-cli credentials:*)",
      "Bash(npx jest *)",
      "Bash(npx expo *)",
      "Bash(npx prettier *)"
    ],
    "deny": [],
    "ask": []
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "supabase"
  ],
  "enabledPlugins": {
    "supabase@claude-plugins-official": false,
    "firebase@firebase": true,
    "vercel@claude-plugins-official": false
  },
  "mcpServers": {
    "heroui-native": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@heroui/native-mcp@latest"
      ]
    }
  }
}
